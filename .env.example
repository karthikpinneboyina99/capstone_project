# Copy this file to .env and fill in real values. Never commit .env.

# --- Database ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/trading_workstation

# --- Alpaca (Paper Trading ONLY — do not point this at a live endpoint) ---
ALPACA_API_KEY=your_alpaca_paper_key_id
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Cerebras (LLM reasoning layer — OpenAI-compatible API, free tier) ---
# Sign up at https://cloud.cerebras.ai → API Keys → generate key.
# Free tier: 5 RPM / 30K input tokens/min / 1M tokens/day. Use the decision cache for backtesting.
LLM_API_KEY=your_cerebras_api_key
LLM_BASE_URL=https://api.cerebras.ai/v1
LLM_MODEL=gpt-oss-120b

# --- Massive (formerly Polygon.io) market data API ---
# Leave blank to use the SimulatorProvider (synthetic GBM data; no API calls)
MASSIVE_API_KEY=
# Optional: override the REST base URL (useful for local proxy / testing)
MASSIVE_BASE_URL=https://api.polygon.io

# --- Optional: news / fundamentals context for the LLM ---
NEWS_API_KEY=
FMP_API_KEY=

# --- App ---
ENVIRONMENT=development
TRADING_MODE=paper
